APP_ENV=development
SECRET_KEY=change-me-in-production
DATABASE_URL=postgresql+psycopg://mywiki:mywiki@localhost:5433/mywiki
DATABASE_CONNECT_TIMEOUT_SECONDS=5
DATABASE_STATEMENT_TIMEOUT_MS=15000
DATABASE_LOCK_TIMEOUT_MS=5000
DATABASE_POOL_TIMEOUT_SECONDS=5
BASE_URL=http://127.0.0.1:5000
MAIL_BACKEND=console
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=
MAIL_FROM_NAME=MyWiki
MAIL_TIMEOUT_SECONDS=10
MAIL_SUBJECT_PREFIX=[MyWiki]
RATELIMIT_STORAGE_URI=memory://

# Gmail 실발송: 2단계 인증 후 만든 16자리 앱 비밀번호를 공백 없이 입력하고
# MAIL_USERNAME과 MAIL_DEFAULT_SENDER에는 같은 전체 Gmail 주소를 입력한 뒤
# MAIL_BACKEND를 smtp로 바꿉니다. 실제 비밀값은 이 예제 파일에 넣지 마세요.

# SQLite fallback when Docker is unavailable
# DATABASE_URL=sqlite:///mywiki.db
